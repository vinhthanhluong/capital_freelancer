---
layout: _default
title: 
description: ''
keyword: ''
vendercss: []
venderjs: []
css: ['contact']
js: ['contact', 'ajaxzip3']
page: contact
---

<main class="p-contact">
    <div class="p-contact__head">
        <div class="container">
            <h1 class="p-contact__heading c-title__h1">応募フォーム</h1>
        </div>
    </div>

    <section class="p-contact__main">
        <div class="container">
            <h2 class="p-contact__title">
                <span class="p-contact__title--sub">■応募先</span>
                <span class="p-contact__title--main">キャピタルアセットプラス株式会社</span>
            </h2>
            <p class="p-contact__desc">以下のフォームに必要事項をご入力のうえ、「送信する」ボタンを押してください。</p>
            <p class="p-contact__note"><span class="c-required">必須</span>は、入力必須項目です。</p>
        
            <form id="mailformpro" class="p-contact__form" action="mailformpro/config.cgi" method="POST">
                <dl class="form__list">
                    <dt class="form__label"><span>氏名</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <input type="text" name="name" required="required" placeholder="（例）鈴木太郎"/>
                    </dd>
            
                    <dt class="form__label"><span>フリガナ</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <input type="text" name="furi" required="required" placeholder="（例）スズキタロウ"/>
                    </dd>
            
                    <dt class="form__label"><span>生年月日</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <div class="form__field--dob">
                            <div class="dob-item">
                                <select name="month" id=""></select>
                            </div>
                            <div class="dob-item">
                                <select name="date" id=""></select>
                            </div>
                            <div class="dob-item">
                                <select name="year" id=""></select>
                            </div>
                        </div>
                    </dd>

                    <dt class="form__label"><span>性別</span></dt>
                    <dd class="form__field">
                        <div class="form__field--radio">
                            <div class="radio-item">
                                <input type="radio" name="gender" value="male" id="male" class="radio-button">
                                <label for="male">男性</label>
                            </div>
                            <div class="radio-item">
                                <input type="radio" name="gender" value="female" id="female" class="radio-button">
                                <label for="female">女性</label>
                            </div>
                        </div>
                    </dd>

                    <dt class="form__label"><span>現在の職業</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <select name="job" id="">
                            <option value="" disabled selected>選択</option>
                        </select>
                    </dd>

                    <dt class="form__label"><span>電話番号</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <input type="tel" name="tel" placeholder="（例）09012345678" inputmode="numeric" pattern="\d*">
                        <p class="form__txt">※半角英数でご入力ください。</p>
                    </dd>

                    <dt class="form__label"><span>メールアドレス</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <input type="email" name="email" placeholder="（例）example@xxx-fc.jp">
                        <p class="form__txt">
                            <span class="u-cl__red u-txt__semi">携帯電話の場合、指定受信・拒否設定を解除してください｡</span><br>
                            <a href="#" target="_blank">ご利用いただけないメールアドレスについて</a>
                        </p>
                    </dd>

                    <dt class="form__label"><span>住所</span><span class="c-required">必須</span></dt>
                    <dd class="form__field">
                        <dl class="form__list form__list--sub">
                            <dt class="form__label"><span>郵便番号</span></dt>
                            <dl class="form__field">
                                <div class="form__field--postcode">
                                    <div class="postcode-input">
                                        <input type="text" name="postcode" placeholder="（例）1234567">
                                    </div>
                                    <span class="postcode-button">郵便番号で検索</span>
                                </div>
                                <p class="form__txt">※半角英数でご入力ください。</p>
                            </dl>

                            <dt class="form__label"><span>都道府県</span></dt>
                            <dl class="form__field">
                                <select name="province">
                                    <option value="" disabled selected>選択</option>
                                </select>
                            </dl>

                            <dt class="form__label"><span>市区町村</span></dt>
                            <dl class="form__field">
                                <select name="city">
                                    <option value="" disabled selected>選択</option>
                                </select>
                            </dl>

                            <dt class="form__label"><span>町名・番地・<br class="pc">建物名</span></dt>
                            <dl class="form__field">
                                <input type="text" name="address">
                            </dl>
                        </dl>
                    </dd>

                    <dt class="form__label"><span>その他</span><span class="form__txt form__txt--right sp">残り1000文字</span></dt>
                    <dd class="form__field form__field--note">
                        <textarea name="note" rows="5"></textarea>
                        <p class="form__txt pc">残り1000文字</p>
                    </dd>
                </dl>
                <p class="form__note">【個人情報の取扱いについて】ご提供いただいた個人情報は、採用選考及び結果等の運知・連絡のために利用します｡<br>それ以外の利用目的または法令等に基づく要請の範囲を超えた利用はしません。</p>
                <button type="submit" class="c-btn__submit">送 信</button>
            </form>
        </div>
    </section>
    
</main>